# Aurelia Dark — Fish shell color theme
# Sets fish_color_* variables to match the Aurelia palette

set -U fish_color_normal         E1E4EA
set -U fish_color_command        6B9EF8  # blue — commands
set -U fish_color_keyword        A97EF8  # purple — keywords
set -U fish_color_quote          62C87E  # green — strings
set -U fish_color_redirection    3DBFCC  # cyan — redirects
set -U fish_color_end            CACFD8  # light neutral — semicolons
set -U fish_color_error          E8647A  # red — errors
set -U fish_color_param          E1E4EA  # foreground — arguments
set -U fish_color_valid_path     --underline
set -U fish_color_option         FAA99F  # orange-light — options/flags
set -U fish_color_comment        525866  # muted — comments
set -U fish_color_selection      --background=F05629
set -U fish_color_search_match   --background=2B303B
set -U fish_color_operator       F05629  # orange — operators
set -U fish_color_escape         F87F6B  # orange-light — escape sequences
set -U fish_color_autosuggestion 525866  # muted — inline suggestions
set -U fish_color_cancel         E8647A  # red — ctrl-c

# Pager
set -U fish_pager_color_progress         F05629
set -U fish_pager_color_background       181B25
set -U fish_pager_color_prefix           F05629
set -U fish_pager_color_completion       E1E4EA
set -U fish_pager_color_description      717784
set -U fish_pager_color_selected_background --background=2B303B
set -U fish_pager_color_selected_prefix        F05629
set -U fish_pager_color_selected_completion    E1E4EA
set -U fish_pager_color_selected_description   CACFD8
